# Neon — pooled connection string from the Neon dashboard (Settings → Connection details)
DATABASE_URL=

# Vercel Blob — create a store in the Vercel dashboard → Storage → Blob → .env snippet
BLOB_READ_WRITE_TOKEN=

# Resend — get an API key at https://resend.com (free tier covers launch).
# If RESEND_API_KEY is missing, signups are still recorded; only the email send is skipped.
RESEND_API_KEY=
# Optional: override the From address. Defaults to "Forevergram <onboarding@resend.dev>"
# (works out of the box for testing). Set to a verified domain for production.
RESEND_FROM_EMAIL=

# Admin dashboard — visit /admin?key=YOUR_KEY to see signups + recent timelines.
# Pick anything long and random; you'll only ever paste it into the URL.
ADMIN_KEY=

# Public site URL used in outbound emails. Falls back to the request origin when omitted.
NEXT_PUBLIC_SITE_URL=https://forevergram.vercel.app
